# ──────────────────────────────────────────────
# FleetOps — Variables d'environnement
# Copier ce fichier en .env.local et remplir
# ──────────────────────────────────────────────

# PostgreSQL (Docker Compose local)
DATABASE_URL="postgresql://admin:secret@localhost:5432/fleetops"

# NextAuth — générer avec: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGER_MOI_EN_PRODUCTION"
NEXTAUTH_URL="http://localhost:3000"

# Agent FleetOps — token optionnel (doit correspondre à --token sur l'agent)
AGENT_AUTH_TOKEN=""

# Cron refresh-all — secret pour protéger POST /api/servers/metrics/refresh-all
CRON_SECRET="CHANGER_MOI_EN_PRODUCTION"

# Environnement
NODE_ENV="development"
